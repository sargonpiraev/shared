{
  "name": "@sargonpiraev/seokit",
  "description": "Two Playwright expect matchers for SEO checks — toHaveMetadata and toHaveJsonLd",
  "version": "0.9.0",
  "private": false,
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sargonpiraev/seokit.git",
    "directory": "packages/seokit"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "default": "./dist/next/index.js"
    },
    "./playwright": {
      "types": "./dist/playwright/index.d.ts",
      "default": "./dist/playwright/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "rm -rf dist && tsx scripts/readme-gen.ts && tsc",
    "prepare": "test -f dist/playwright/index.js || npm run build",
    "check-types": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:example": "npm test -w seokit-example",
    "readme:gen": "tsx scripts/readme-gen.ts",
    "skill:init": "mkdir -p skills && cd skills && npx skills init seokit",
    "release:dry-run": "semantic-release --dry-run"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.51.0"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@repo/typescript-config": "*",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.2"
  },
  "homepage": "https://sargonpiraev.github.io/seokit/docs",
  "llms": "https://sargonpiraev.github.io/seokit/llms.txt",
  "llmsFull": "https://sargonpiraev.github.io/seokit/llms-full.txt",
  "skills": "https://github.com/sargonpiraev/seokit/tree/main/packages/seokit/skills/seokit",
  "agents": {
    "skills": [
      {
        "name": "seokit",
        "path": "./skills/seokit"
      }
    ]
  }
}
